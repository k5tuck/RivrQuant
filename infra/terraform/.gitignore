# Local variable files — contain secrets, never commit
terraform.tfvars
*.tfvars
!terraform.tfvars.example

# Terraform working directories
.terraform/
.terraform.lock.hcl

# State files — commit only if you are NOT using a remote backend
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Crash log
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
